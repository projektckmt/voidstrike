ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# HackTheBox App Token (account settings → App Tokens). Enables the challenge
# runner to spawn/reset/teardown machines via the HTB API. Optional.
HTB_TOKEN=
# Override only if the API base differs from labs.hackthebox.com/api/v4.
# HTB_API_BASE=https://labs.hackthebox.com/api/v4

POSTGRES_USER=voidstrike
POSTGRES_PASSWORD=changeme
POSTGRES_DB=voidstrike
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_URI=bolt://neo4j:7687

REDIS_URL=redis://redis:6379/0

LITELLM_PROXY_URL=http://litellm:4000
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=voidstrike

DEFAULT_PROFILE=eco
DEFAULT_BUDGET_USD=10.00

# Adaptive thinking for the reasoning-heavy subagents (exploit, postex).
# Forces the model to deliberate between actions (diagnose-before-retry) instead
# of reflexively firing the next tool call, which is what causes the expensive
# retry detours. Value is an effort level: low | medium | high | xhigh | max
# (Opus 4.7/4.8 surface; Sonnet 4.6 is clamped to high). Empty/unset disables it
# (the model runs as before). `high` is a reasonable starting point.
VOIDSTRIKE_THINKING_EFFORT=high

KALI_IMAGE=voidstrike/kali:pinned
SANDBOX_NETWORK=voidstrike_ops
