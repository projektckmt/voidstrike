# Native provider keys. Any of these may be left blank (or left as the `...`
# placeholder below — both count as "unset"): if a key is absent but
# OPENROUTER_API_KEY is set, that provider's models are served via OpenRouter
# automatically (so an OpenRouter-only setup can still run eco/max/test). This
# holds for both the direct path and the LiteLLM proxy (the proxy's startup
# bootstrap applies the same remap). Setting a real native key reverts that
# provider to its direct SDK (keeps Anthropic prompt caching etc.).
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...
# Required by the `qwen` profile (openrouter:qwen/qwen3.7-max), any other
# openrouter: model, AND the key-fallback above. Get one at
# https://openrouter.ai/keys.
OPENROUTER_API_KEY=sk-or-...

# HackTheBox App Token (account settings → App Tokens). Enables the challenge
# runner to spawn/reset/teardown machines via the HTB API. Optional.
HTB_TOKEN=
# Override only if the API base differs from labs.hackthebox.com/api/v4.
# HTB_API_BASE=https://labs.hackthebox.com/api/v4

# Researcher open-web search (`research__web_search`). Optional: with no key the
# tool falls back to keyless DuckDuckGo (best-effort, may throttle). Set a key
# for cleaner, more reliable results — Tavily takes priority, else BRAVE_API_KEY.
TAVILY_API_KEY=
# BRAVE_API_KEY=

POSTGRES_USER=voidstrike
POSTGRES_PASSWORD=changeme
POSTGRES_DB=voidstrike
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_URI=bolt://neo4j:7687

REDIS_URL=redis://redis:6379/0

# LiteLLM proxy. ON by default (unset = enabled) — routes all model calls through
# the proxy, which gives provider fallback (HIGH→OpenAI→Google etc.), a Redis
# response cache, spend/budget tracking, and Langfuse observability, and routes
# every model including the qwen/OpenRouter profile. Routing chains live in
# infra/litellm-config.yaml. Set VOIDSTRIKE_USE_LITELLM=false to call provider
# SDKs directly instead (keeps Anthropic-native prompt caching — cheaper on
# Opus-heavy runs). Requires the proxy running + LITELLM_MASTER_KEY below.
VOIDSTRIKE_USE_LITELLM=true
LITELLM_PROXY_URL=http://litellm:4000
# Required when VOIDSTRIKE_USE_LITELLM=true: the proxy's auth key (also used by
# the proxy itself as its master key). Pick any strong secret, prefix `sk-`.
LITELLM_MASTER_KEY=sk-changeme
# Postgres URL the proxy uses for spend/budget tracking. Reuses the app DB.
LITELLM_DATABASE_URL=postgresql://voidstrike:changeme@postgres:5432/voidstrike
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=voidstrike

DEFAULT_PROFILE=eco
DEFAULT_BUDGET_USD=10.00

# Adaptive thinking for the reasoning-heavy subagents (exploit, postex).
# Forces the model to deliberate between actions (diagnose-before-retry) instead
# of reflexively firing the next tool call, which is what causes the expensive
# retry detours. Value is an effort level: low | medium | high | xhigh | max
# (Opus 4.7/4.8 surface; Sonnet 4.6 is clamped to high). Empty/unset disables it
# (the model runs as before). `high` is a reasonable starting point.
VOIDSTRIKE_THINKING_EFFORT=high

KALI_IMAGE=voidstrike/kali:pinned
SANDBOX_NETWORK=voidstrike_ops
